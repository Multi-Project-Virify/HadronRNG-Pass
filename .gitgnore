# Rust build output
/target/

# Cargo
# Для библиотек Cargo.lock обычно НЕ коммитится
Cargo.lock

# Rust backup files
**/*.rs.bk

# Generated by rustfmt
*.rs.bk

# IDE

# Visual Studio Code
.vscode/

# JetBrains (IntelliJ IDEA, RustRover, CLion)
.idea/

# Fleet
.fleet/

# Zed
.zed/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# OS files

# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
.directory

# Logs
*.log

# Temporary files
tmp/
temp/
*.tmp

# Benchmark output
bench-results/
criterion/

# Fuzzing
artifacts/
corpus/

# Coverage
coverage/
*.profraw
*.profdata

# LLVM
default.profraw

# Generated documentation
/doc/

# Local environment
.env
.env.local

# Backup files
*.bak
*.old
*.orig

# Archives
*.zip
*.7z
*.tar
*.gz
*.rar

# Binary files
*.exe
*.dll
*.so
*.dylib

# Security
*.pem
*.key
*.p12
*.pfx

# Test output
test-output/